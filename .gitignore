# ==========================
# Terraform
# ==========================

# Local .terraform directories
**/.terraform/*

# .tfstate files (contain real infrastructure state — sensitive!)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely to contain passwords, private keys, etc.)
*.tfvars
*.tfvars.json

# Ignore override files (used to override resources locally)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Provider lock files (regenerated by terraform init)
.terraform.lock.hcl

# ==========================
# IDE & Editor
# ==========================
.idea/
.vscode/
*.swp
*.swo
*~

# ==========================
# OS
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Misc
# ==========================
*.bak
*.tmp
*.log
